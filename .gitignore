# ===== Data =====
# Raw Olist CSVs are large and not ours to redistribute (Kaggle license) —
# document the source and keep the CSV's out of git.
# Scripts in data folder will be used to download the data locally.

data/*.csv
data/*.zip

# ===== Python =====
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# Virtual / conda environments
venv/
env/
.venv/
.conda/

# ===== Jupyter =====
.ipynb_checkpoints/
*.ipynb_checkpoints

# ===== Environment / secrets =====
.env
.env.*
*.pem
config.ini
secrets.yaml

# ===== PostgreSQL =====
*.sql.bak
*.dump
*.backup
pgdata/

# ===== Tableau =====
# Keep .twbx (packaged workbook) but ignore temp/local-only Tableau files
*.twb
*.tde
*.hyper
*.tableau-prep

# ===== OS junk =====
.DS_Store
Thumbs.db
desktop.ini

# ===== Editor/IDE =====
.vscode/
.idea/
*.swp
*.swo

# ===== Logs =====
*.log
logs/
